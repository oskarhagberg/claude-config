{
  "statusLine": {
    "type": "command",
    "command": "bash /Users/oskar/.claude/statusline-command.sh"
  },
  "permissions": {
    "allow": [
      "Bash(echo:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(pnpm ls:*)",
      "Bash(pnpm test:*)",
      "Bash(tracey:*)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:tracey.bearcove.eu)",
      "mcp__tracey__*"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)"
    ]
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true
  },
  "skipDangerousModePermissionPrompt": true
}
